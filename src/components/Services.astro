---
interface Service {
  title: string;
  description: string;
  icon: string;
}

const services: Service[] = [
  {
    title: 'Backend Development',
    description:
      'Building robust, scalable APIs and backend systems using C# and .NET / .NET Core. Experience with enterprise-level banking and CRM systems.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>`,
  },
  {
    title: 'Database Design & Optimization',
    description:
      'Relational database design with MSSQL and SQL Server. Query optimization and data modeling for high-performance applications.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>`,
  },
  {
    title: 'CRM & Business Systems',
    description:
      'Custom solutions built on or integrated with Microsoft Dynamics CRM. Tailored business workflows and integrations for enterprise clients.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  },
  {
    title: 'Mobile Development',
    description:
      'Cross-platform mobile applications using Xamarin Forms. Delivering consistent, performant apps for both iOS and Android from a single codebase.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
  },
  {
    title: 'DevOps & CI/CD',
    description:
      'Azure DevOps pipeline setup, repository management, deployment automation, and on-premise agent configuration for continuous delivery.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
  },
  {
    title: 'Legacy System Integration',
    description:
      'Connecting modern APIs with existing third-party systems — payment gateways, telecom integrations, and external APIs for seamless data flow.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
  },
];
---

<section
  id="services"
  class="py-20 lg:py-28 bg-navy-900/50"
  aria-labelledby="services-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <span class="text-accent-400 text-sm font-semibold tracking-widest uppercase mb-3 block">
        Expertise
      </span>
      <h2 id="services-heading" class="text-3xl sm:text-4xl font-bold text-slate-50 mb-4">
        What I Do
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        From backend APIs to mobile apps — I build software that solves real business problems.
      </p>
    </div>

    <!-- Services grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
      role="list"
    >
      {services.map((service, i) => (
        <article
          class={`reveal reveal-delay-${Math.min(i + 1, 5)} group flex flex-col gap-4 p-6 rounded-2xl bg-white/3 border border-white/8 hover:border-accent-500/30 hover:bg-white/5 transition-all duration-300`}
          role="listitem"
        >
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-accent-500/10 border border-accent-500/20 flex items-center justify-center text-accent-400 group-hover:bg-accent-500/15 transition-colors duration-300">
            <Fragment set:html={service.icon} />
          </div>
          <!-- Content -->
          <div>
            <h3 class="text-base font-semibold text-slate-100 mb-2">{service.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{service.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.05s; }
  .reveal-delay-2 { transition-delay: 0.1s; }
  .reveal-delay-3 { transition-delay: 0.15s; }
  .reveal-delay-4 { transition-delay: 0.2s; }
  .reveal-delay-5 { transition-delay: 0.25s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const els = document.querySelectorAll('#services .reveal');
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
    { threshold: 0.1 }
  );
  els.forEach((el) => obs.observe(el));
</script>
