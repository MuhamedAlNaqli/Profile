---
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  role="banner"
>
  <nav
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href="#hero"
      class="flex items-center gap-2 group"
      aria-label="Muhamed Al Naqli — Home"
    >
      <div
        class="w-9 h-9 rounded-lg bg-accent-500 flex items-center justify-center text-navy-950 font-bold text-sm tracking-tight group-hover:bg-accent-400 transition-colors"
        aria-hidden="true"
      >
        MAN
      </div>
      <span class="hidden sm:block font-semibold text-slate-100 text-sm">
        Muhamed Al Naqli
      </span>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      {['About', 'Services', 'Projects', 'Contact'].map((item) => (
        <li>
          <a
            href={`#${item.toLowerCase()}`}
            class="px-4 py-2 text-sm text-slate-400 hover:text-slate-100 hover:bg-white/5 rounded-lg transition-all duration-200"
          >
            {item}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <a
        href="#contact"
        class="hidden md:inline-flex items-center px-4 py-2 bg-accent-500 hover:bg-accent-400 text-navy-950 text-sm font-semibold rounded-lg transition-all duration-200 shadow-lg shadow-accent-500/20"
      >
        Get in Touch
      </a>

      <!-- Hamburger button -->
      <button
        id="menu-btn"
        class="md:hidden p-2 rounded-lg text-slate-400 hover:text-slate-100 hover:bg-white/5 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-white/10 bg-navy-900/95 backdrop-blur-md"
    role="menu"
    aria-label="Mobile navigation"
  >
    <ul class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1" role="list">
      {['About', 'Services', 'Projects', 'Contact'].map((item) => (
        <li role="none">
          <a
            href={`#${item.toLowerCase()}`}
            role="menuitem"
            class="nav-mobile-link block px-4 py-3 text-sm text-slate-300 hover:text-slate-100 hover:bg-white/5 rounded-lg transition-all duration-200"
          >
            {item}
          </a>
        </li>
      ))}
      <li role="none">
        <a
          href="#contact"
          role="menuitem"
          class="nav-mobile-link block mt-2 px-4 py-3 bg-accent-500 hover:bg-accent-400 text-navy-950 text-sm font-semibold rounded-lg text-center transition-all duration-200"
        >
          Get in Touch
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar') as HTMLElement;
  const menuBtn = document.getElementById('menu-btn') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  const iconOpen = document.getElementById('icon-open') as HTMLElement;
  const iconClose = document.getElementById('icon-close') as HTMLElement;
  const mobileLinks = document.querySelectorAll('.nav-mobile-link');

  // Sticky nav style on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-navy-900/95', 'backdrop-blur-md', 'border-b', 'border-white/5', 'shadow-xl');
    } else {
      navbar.classList.remove('bg-navy-900/95', 'backdrop-blur-md', 'border-b', 'border-white/5', 'shadow-xl');
    }
  });

  // Mobile menu toggle
  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close mobile menu on link click
  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      menuBtn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
