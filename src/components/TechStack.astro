---

<section
  id="techstack"
  class="py-20 lg:py-28"
  aria-labelledby="techstack-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal text-center mb-14">
      <span class="text-accent-400 text-sm font-semibold tracking-widest uppercase mb-3 block">
        Tools & Languages
      </span>
      <h2 id="techstack-heading" class="text-3xl sm:text-4xl font-bold text-slate-50 mb-4">
        Technologies I Use
      </h2>
    </div>

    <ul
      class="reveal grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
      aria-label="Technology list"
    >
      {techs.map((tech) => (
        <li>
          <div class="group flex flex-col items-center gap-3 p-5 rounded-2xl bg-white/3 border border-white/8 hover:border-accent-500/30 hover:bg-white/5 transition-all duration-300 cursor-default">
            <span class="text-slate-400 group-hover:text-accent-400 transition-colors duration-300">
              <Fragment set:html={tech.icon} />
            </span>
            <span class="text-xs text-slate-400 font-medium text-center leading-snug">
              {tech.name}
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const els = document.querySelectorAll('#techstack .reveal');
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
    { threshold: 0.1 }
  );
  els.forEach((el) => obs.observe(el));
</script>
