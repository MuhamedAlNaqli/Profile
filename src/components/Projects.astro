---
interface Project {
  name: string;
  description: string;
  tech: string[];
  link?: string;
}

const projects: Project[] = [
  {
    name: 'Telecom CRM Platform — MTEL Austria & Switzerland',
    description:
      'Custom CRM web application built on top of Microsoft Dynamics CRM for the Austrian and Swiss telecom market. Supports full customer lifecycle: contract creation, multi-system integration, SMS, payments and voucher management.',
    tech: ['C#', '.NET', 'Microsoft Dynamics CRM', 'REST APIs'],
    link: 'https://sales.mtel.at/',
  },
  {
    name: 'Pharmacy Finder App — Apoteke Sarajevo',
    description:
      'Cross-platform mobile application for finding medicines across all Sarajevo pharmacies. Features include medicine search, pharmacy locations on Google Maps, and a personal reservation list.',
    tech: ['Xamarin Forms', 'Google Maps API', 'C#'],
    link: 'http://www.apoteke-sarajevo.ba/',
  },
  {
    name: 'Legal Case Management System — Your Rights BiH',
    description:
      'Web application for registering and tracking the full legal process for endangered persons. Features include case management, user roles, office management, and report generation.',
    tech: ['C#', '.NET', 'MSSQL'],
    link: 'https://laidb.vpbih.org/',
  },
  {
    name: 'Banking System Enhancement — NatWest (via additiv)',
    description:
      'Backend development on financial systems — planning, implementing and deploying new features and bug fixes on an enterprise banking platform.',
    tech: ['C#', '.NET Core', 'SQL Server', 'Agile'],
  },
  {
    name: 'HORECA POS System — ConfigPOS',
    description:
      'A complete Point-of-Sale solution for the catering industry. Includes a Web API for multi-device data distribution and a WPF desktop app for order management, billing, and shift management.',
    tech: ['C#', '.NET', 'WPF', 'Web API', 'MSSQL'],
  },
  {
    name: 'Order Management System — OrderE',
    description:
      'Web application for creating and managing work orders, build orders and delivery orders. Built as part of the SPARK startup program.',
    tech: ['PHP Laravel', 'MySQL'],
  },
];
---

<section
  id="projects"
  class="py-20 lg:py-28 bg-navy-900/50"
  aria-labelledby="projects-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <span class="text-accent-400 text-sm font-semibold tracking-widest uppercase mb-3 block">
        Portfolio
      </span>
      <h2 id="projects-heading" class="text-3xl sm:text-4xl font-bold text-slate-50 mb-4">
        Selected Projects
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        A selection of real-world systems I've designed, built, and delivered.
      </p>
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project, i) => (
        <article
          class={`reveal reveal-delay-${Math.min((i % 4) + 1, 4)} group flex flex-col p-6 rounded-2xl bg-white/3 border border-white/8 hover:border-accent-500/30 hover:bg-white/5 transition-all duration-300`}
        >
          <!-- Top: name + external link -->
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="font-semibold text-slate-100 text-base leading-snug flex-1">
              {project.name}
            </h3>
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 p-2 rounded-lg bg-white/5 hover:bg-accent-500/10 text-slate-400 hover:text-accent-400 transition-colors"
                aria-label={`View ${project.name} (opens in new tab)`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>

          <!-- Description -->
          <p class="text-sm text-slate-400 leading-relaxed flex-1 mb-4">
            {project.description}
          </p>

          <!-- Tech tags -->
          <ul class="flex flex-wrap gap-2" aria-label="Technologies">
            {project.tech.map((t) => (
              <li>
                <span class="px-2.5 py-1 bg-accent-500/8 border border-accent-500/15 rounded-md text-xs text-accent-300 font-medium">
                  {t}
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.05s; }
  .reveal-delay-2 { transition-delay: 0.1s; }
  .reveal-delay-3 { transition-delay: 0.15s; }
  .reveal-delay-4 { transition-delay: 0.2s; }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const els = document.querySelectorAll('#projects .reveal');
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
    { threshold: 0.08 }
  );
  els.forEach((el) => obs.observe(el));
</script>
